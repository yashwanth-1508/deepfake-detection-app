# Exclude virtual environment
venv/
.venv/
env/

# Exclude Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Exclude large datasets and raw data
kaggle_data/
multiface_data/
multiface_training_data/
*.mp4
*.zip

# Exclude IDE and system files
.DS_Store
.vscode/
.idea/
.git/

# Only keep the specific weights we need
model/weights/*
!model/weights/model.pth
!model/weights/fine_tuned_head.pth
!model/weights/efficientnetb4_b0.pth
!model/weights/__init__.py
!model/weights/face_detector/*

